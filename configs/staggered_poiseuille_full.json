{
    "description": "Two-phase framework run as channel flow: uniform liquid (no droplet), no_slip top/bottom, inlet left, outflow right",

    "physical_params": {
        "rho1": 0.001225,
        "rho2": 1.0,
        "Re1": 5.0,
        "Re2": 200.0,
        "We1": 0.1,
        "We2": 100.0,
        "Pe": 10.0,
        "epsilon": 0.015,
        "alpha": 1.0,
        "phase_penalty": 1000.0,
        "contact_angle": 60,
        "include_gravity": false,
        "g": -1.0,
        "atm_pressure": 0.0,
        "Fr": 0.5,
        "lambda_willmore": 0,
        "epsilon_willmore": 0,
        "surface_tension": {
            "smooth_curvature": true,
            "smoothing_radius": 1
        }
    },

    "grid_params": {
        "Lx": 1.0,
        "Ly": 1.0,
        "Nx": 64,
        "Ny": 64
    },

    "time_params": {
        "dt": 1e-2,
        "dt_initial": 1e-2,
        "t_max": 0.2,
        "checkpoint_interval": 10,
        "cfl_number": 0.01,
        "capillary_cfl_number": 10.0,
        "curvature_cfl_number": 10.0
    },

    "initial_conditions": {
        "type": "uniform_liquid",
        "pressure_drop": 0.02
    },

    "restart": {
        "restart_from": null
    },

    "boundary_conditions": {
        "pressure": {
            "top": "neumann",
            "bottom": "neumann",
            "left": "neumann",
            "right": "dirichlet",
            "dirichlet_values": {
                "right": 0.0
            },
            "open_pressure": 0.0
        },
        "velocity": {
            "top": "no_slip",
            "bottom": "no_slip",
            "left": "dirichlet",
            "right": "do_nothing",
            "dirichlet_values": {
                "left": {
                    "u": 1.0,
                    "v": 0.0
                }
            },
            "dirichlet_profiles": {
                "left": {
                    "type": "linear"
                }
            }
        },
        "phase_field": {
            "top": "neumann",
            "bottom": "contact_angle",
            "left": "neumann",
            "right": "neumann",
            "contact_angle_method": "simple",
            "use_cox_voinov": true,
            "cox_voinov_coefficient": 1.5,
            "cox_voinov_exponent": 0.333
        },
        "chemical_potential": {
            "top": "zero_flux",
            "bottom": "zero_flux",
            "left": "zero_flux",
            "right": "zero_flux"
        },
        "advection": {
            "top": "open",
            "bottom": "impermeable",
            "left": "open",
            "right": "open",
            "cout": 1.0
        }
    },

    "solver_params": {
        "pressure_solver": {
            "backend": "pyamg",
            "accel": "bicgstab",
            "tol": 0.05,
            "maxiter": 15000
        },
        "correction_solver": {
            "backend": "pyamg",
            "accel": "bicgstab",
            "tol": 0.05,
            "maxiter": 15000
        },
        "velocity_layout": "staggered",
        "ppe": {
            "mean_div_threshold": 0.5,
            "max_div_threshold": 0.1,
            "use_local_ppe": false,
            "local_threshold_factor": 0.2,
            "max_iterations": 600,
            "buffer_size": 5,
            "under_relaxation": 0.5
        }
    }
}
