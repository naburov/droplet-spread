{
    "liquds": {
        "2": "droplet of water",
        "1": "air"
    },
    "physical_params": {
        "rho2": 1000.0,
        "Re2": 150.0,
        "We2": 10000.0,
        "rho1": 1.0,
        "Re1": 10.0,
        "We1": 1.0,
        "Pe": 1.0,
        "epsilon": 0.02,
        "alpha": 1.0,
        "phase_penalty": 1000.0,
        "contact_angle": 120,
        "chemical_potential_bc_strength": 0.1,
        "include_gravity": true,
        "Fr": 1.0,
        "g": -10.0,
        "atm_pressure": -10000.0
    },
    "grid_params": {
        "Lx": 1.0,
        "Ly": 1.0,
        "Nx": 128,
        "Ny": 128
    },
    "time_params": {
        "dt": 0.00025,
        "t_max": 1.0,
        "checkpoint_interval": 5,
        "dt_initial": 0.00025,
        "cfl_number": 0.01
    },
    "initial_conditions": {
        "droplet_radius": 0.2
    },
    "boundary_conditions": {
        "pressure": {
            "top": "dirichlet",
            "bottom": "dirichlet", 
            "left": "dirichlet",
            "right": "dirichlet"
        },
        "velocity": {
            "top": "neumann",
            "bottom": "no_slip",
            "left": "periodic",
            "right": "periodic"
        },
        "phase_field": {
            "top": "neumann",
            "bottom": "contact_angle",
            "left": "periodic",
            "right": "periodic"
        }
    },
    "solver_params": {
        "pressure_solver": {
            "backend": "pyamg",
            "accel": "bicgstab",
            "tol": 0.05,
            "maxiter": 10000
        },
        "correction_solver": {
            "backend": "pyamg", 
            "accel": "bicgstab",
            "tol": 0.05,
            "maxiter": 10000
        },
        "divergence_threshold": 0.05,
        "max_correction_iterations": 100
    },
    "plotting_params": {
        "figure_size": [18, 14],
        "dpi": 100,
        "colormap": "viridis",
        "save_format": "png",
        "show_velocity_vectors": true,
        "vector_density": 8,
        "vector_scale": 50,
        "show_contours": true,
        "contour_levels": 20,
        "show_colorbar": true,
        "title_fontsize": 16,
        "label_fontsize": 14,
        "tick_fontsize": 12
    },
    "restart": {
        "restart_from": "None"
    }
} 