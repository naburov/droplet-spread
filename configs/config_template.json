{
    "description": "Droplet spreading, 60° contact angle. Base template, sessile droplet on surface. Static atmosphere: do_nothing (zero stress ∂u/∂n=0) at top/left/right so both value and derivative ≈0 there.",
    
    "physical_params": {
        "rho1": 0.01225,
        "rho2": 1.0,
        "Re1": 35.0,
        "Re2": 100.0,
        "We1": 10.0,
        "We2": 0.5,
        "Pe": 10.0,
        "epsilon": 0.025,
        "contact_angle": 60,
        "include_gravity": true,
        "Fr": 1.0,
        "g": -1.0,
        "atm_pressure": 0.0,
        "lambda_willmore": 0,
        "epsilon_willmore": 0
    },
    
    "grid_params": {
        "Lx": 1.0,
        "Ly": 1.0,
        "Nx": 128,
        "Ny": 128
    },
    
    "time_params": {
        "dt": 0.0001,
        "dt_initial": 0.0005,
        "t_max": 2.0,
        "checkpoint_interval": 100,
        "cfl_number": 0.1,
        "capillary_cfl_number": 1.0,
        "curvature_cfl_number": 1.0
    },
    
    "initial_conditions": {
        "droplet_radius": 0.15,
        "droplet_center_x": 0.5,
        "droplet_center_y": 0.0
    },
    
    "boundary_conditions": {
        "pressure": {
            "top": "open",
            "bottom": "neumann",
            "left": "neumann",
            "right": "neumann",
            "open_pressure": 0.0
        },
        "velocity": {
            "top": "dirichlet",
            "bottom": "navier_slip",
            "slip_length": 1.0,
            "navier_slip_phase_aware": false,
            "slip_length_liquid": 1.0,
            "slip_length_gas": 0.0,
            "strip_compatibility_top": true,
            "strip_compatibility_width": 2,
            "strip_compatibility_next_relax": 0.0,
            "bottom_strip_compatibility": false,
            "bottom_strip_compatibility_pad": 2,
            "bottom_strip_compatibility_exclude_side": 2,
            "left": "dirichlet",
            "right": "dirichlet",
            "dirichlet_values": {
                "top": {"u": 0.0, "v": 0.0},
                "left": {"u": 0.0, "v": 0.0},
                "right": {"u": 0.0, "v": 0.0}
            }
        },
        "phase_field": {
            "top": "neumann",
            "bottom": "contact_angle",
            "left": "neumann",
            "right": "neumann",
            "contact_angle_method": "simple",
            "use_cox_voinov": true,
            "cox_voinov_coefficient": 1.0,
            "cox_voinov_exponent": 0.333
        },
        "chemical_potential": {
            "top": "zero_flux",
            "bottom": "zero_flux",
            "left": "zero_flux",
            "right": "zero_flux"
        },
        "advection": {
            "top": "impermeable",
            "bottom": "impermeable",
            "left": "impermeable",
            "right": "impermeable",
            "cout": 1.0
        }
    },
    
    "solver_params": {
        "pressure_solver": {
            "backend": "pyamg",
            "accel": "bicgstab",
            "tol": 0.05,
            "maxiter": 1000
        },
        "correction_solver": {
            "backend": "pyamg",
            "accel": "bicgstab",
            "tol": 0.05,
            "maxiter": 1000
        },
        "ppe": {
            "mean_div_threshold": 0.01,
            "max_div_threshold": 0.15,
            "max_iterations": 1000,
            "boundary_conditions": {
                "top": "dirichlet",
                "bottom": "neumann",
                "left": "neumann",
                "right": "neumann"
            }
        }
    },
    
    "visualization": {
        "use_pyvista": false
    },
    
    "restart": {
        "restart_from": null
    }
}
